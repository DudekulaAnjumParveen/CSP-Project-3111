<!DOCTYPE html>
<html>
<head>

<title>Dashboard</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="/css/dashboard.css">

</head>

<body class="bg-light">

<div class="wrapper">

    <!-- Sidebar -->
    <div class="sidebar">

        <h2>🏡 Smart Village</h2>

        <a href="#">🏠 Dashboard</a>

        <a href="/village">🏘 Village Overview</a>

        <a href="#">💧 Water Supply</a>

        <a href="#">💡 Street Lights</a>

        <a href="#">🗑 Waste Management</a>

        <a href="#">🛣 Roads & Drainage</a>

        <a href="/">📋 Complaint Management</a>

        <a href="#">🏥 Health</a>

        <a href="#">⚡ Electricity</a>

        <a href="#">👷 Staff Assignment</a>

        <a href="#">📍 Evidence</a>

        <a href="#">📊 Reports</a>

        <a href="#">🔔 Notifications</a>

        <a href="#">⚙ Admin</a>

        <a href="/">🚪 Logout</a>

    </div>

    <!-- Main Content -->
    <div class="main">

        <h1>
🏡 SMART VILLAGE MONITORING DASHBOARD
</h1>

<p>
Welcome Admin 👋
Manage your entire village from one dashboard.
</p>

<hr>

        <div class="cards">

    <div class="card">
       <p><%= village ? village.population : 0 %></p>
    </div>

    <div class="card">
       <p><%= village ? village.houses : 0 %></p>
    </div>

    <div class="card">
        <p><%= village ? village.schools : 0 %></p>
    </div>

    <div class="card">
        <p><%= village ? village.hospitals : 0 %></p>
    </div>

    <div class="card">
        <p><%= village ? village.waterTanks : 0 %></p>
    </div>

    <div class="card">
        <h3>💡 Street Lights</h3>
        <p>320</p>
    </div>

    <div class="card">
        <h3>📋 Complaints</h3>
        <p><%= totalComplaints %></p>
    </div>

    <div class="card">
        <h3>👷 Staff</h3>
        <p>25</p>
    </div>

</div>

    </div>

</div>

</body>
</html>