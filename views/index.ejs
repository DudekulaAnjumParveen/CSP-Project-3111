<!DOCTYPE html>
<html>

<head>

<title>
Smart Village Monitoring Dashboard
</title>

<link rel="stylesheet" href="/style.css">

</head>

<body>

<!-- HEADER -->

<h2 id="clock"></h2>

<button onclick="toggleDarkMode()">

Dark Mode

</button>
<div class="header">

<div class="left">

<h1>
Smart Village Monitoring Dashboard
</h1>

<p>
Student : DUDEKULA ANJUM PARVEEN
</p>

<p>
Hall Ticket : 3111
</p>

<p>
Batch : CSP II Batch - A
</p>

<p>
Guide : Dr SMP.Qubeb
</p>

</div>

<div class="right">

<div class="college-box">

<div class="college-box">

<img
src="/gates-logo.jpeg"
class="college-logo"
alt="GATES Logo">

</div>

<h1 class="college-name">
GATES
</h1>

<h2 class="college-sub">
INSTITUTE OF TECHNOLOGY
</h2>

<h3 class="auto">
AUTONOMOUS
</h3>

</div>

<div class="buttons">

<a
href="https://www.gatesit.ac.in/"
target="_blank">

<button>
Website
</button>

</a>

<a
href="https://www.instagram.com/gates_institute_of_technology/"
target="_blank">

<button>
Instagram
</button>

</a>

<a
href="https://www.facebook.com/GATESITGOOTY/"
target="_blank">

<button>
Facebook
</button>

</a>

<a
href="https://www.youtube.com/@gatesinstituteoftechnolo9432"
target="_blank">

<button>
YouTube
</button>

</a>

<a
href="https://www.google.com/maps/search/?api=1&query=GATES+Institute+of+Technology+Gooty"
target="_blank">

<button>
Directions
</button>

</a>

</div>

</div>

</div>

<!-- CARDS -->

<div class="cards">

<div class="card green">

<h2><%= complaints.length %></h2>

<p>
Total Complaints
</p>

</div>

<div class="card blue">

<h2><%= complaints.filter(c => !c.status || c.status === 'Pending').length %></h2>

<p>
Pending Complaints
</p>

</div>

<div class="card yellow">

<h2><%= complaints.filter(c => c.status === 'Solved').length %></h2>

<p>
Solved Complaints
</p>

</div>

<div class="card pink">

<h2><%= complaints.length %></h2>

<p>
Village Records
</p>

</div>

</div>

<!-- MAIN -->

<div class="main">

<!-- FORM -->

<div class="form-section">

<h2>
Add Complaint
</h2>

<form method="POST">

<input
type="text"
name="name"
placeholder="Enter Name"
required>

<input
type="text"
name="village"
placeholder="Enter Village"
required>

<input
type="text"
name="contact"
placeholder="Enter Contact Number"
required>

<input
type="text"
name="issue"
placeholder="Issue or Need Identified"
required>

<input
type="text"
name="cspTopic"
placeholder="CSP Topic"
required>

<select name="status">

<option>Pending</option>

<option>Solved</option>

</select>

<textarea
name="remarks"
placeholder="Remarks">
</textarea>

<input
type="text"
name="evidence"
placeholder="Evidence Caption">

<button type="submit">

Submit

</button>

</form>

</div>

<!-- RECORDS -->

<div class="records">

<h2>
Complaint Records
</h2>
<input
type="text"
id="searchInput"
placeholder="Search records..."
onkeyup="searchRecords()">
<% complaints.forEach((c) => { %>

<div class="record-card">
<p>

<b>Date:</b>

<%= c.date %>

</p>
<h3>
<%= c.issue %>
</h3>

<p>
<b>Name:</b>
<%= c.name %>
</p>

<p>
<b>Village:</b>
<%= c.village %>
</p>

<p>
<b>Contact:</b>
<%= c.contact %>
</p>

<p>
<b>CSP Topic:</b>
<%= c.cspTopic %>
</p>

<p>

<b>Status:</b>

<span class="<%= c.status %>">

<%= c.status %>

</span>

</p>

<p>
<b>Remarks:</b>
<%= c.remarks %>
</p>

<p>
<b>Evidence:</b>
<%= c.evidence %>
</p>

<a href="/delete/<%= c._id %>" class="delete-btn">
Delete
</a>

<a href="/solve/<%= c._id %>" class="solve-btn">
Mark as Solved
</a>

</div>

<% }) %>

</div>

</div>

</div>
<script>

function searchRecords() {

let input =
document.getElementById("searchInput")
.value.toLowerCase();

let cards =
document.getElementsByClassName("record-card");

for(let i = 0; i < cards.length; i++) {

let text =
cards[i].innerText.toLowerCase();

cards[i].style.display =
text.includes(input)
? "block"
: "none";

}

}

</script>
<footer>

Smart Village Monitoring Dashboard
© 2026 CSP Project

</footer>
<script>

function toggleDarkMode(){

document.body.classList.toggle("dark");

}

</script>
<script>

setInterval(() => {

document.getElementById("clock")
.innerHTML =
new Date().toLocaleTimeString();

},1000);

</script>
<button id="topBtn">

↑

</button>
<script>

const topBtn =
document.getElementById("topBtn");

window.onscroll = function(){

if(document.body.scrollTop > 100
|| document.documentElement.scrollTop > 100){

topBtn.style.display = "block";

}else{

topBtn.style.display = "none";

}

};

topBtn.onclick = function(){

window.scrollTo({

top:0,

behavior:'smooth'

});

};

</script>
</body>
</html>